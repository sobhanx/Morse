# Django core
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Product display name (optional; default is Morse)
# PRODUCT_NAME=Morse

# Public URL where Morse is hosted (used in embed scripts and links)
PUBLIC_BASE_URL=http://127.0.0.1:8002

# Comma-separated origins allowed for CSRF (customer sites that POST to your API)
# Example: https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=

# Enable cross-site cookies when the widget iframe is embedded on customer domains.
# Set to 1 in production with HTTPS. Leave empty for local-only development.
WIDGET_EMBED_CROSS_ORIGIN=

# Set to 1 when WIDGET_EMBED_CROSS_ORIGIN=1 and you serve over HTTPS
SESSION_COOKIE_SECURE=

# SMS.ir credentials (required for phone/SMS login)
SMS_IR_API_KEY=
SMS_IR_LINE_NUMBER=
SMS_IR_VERIFY_TEMPLATE_ID=

# Optional overrides for `python manage.py seed_demo`
DEMO_ADMIN_PHONE=09000000000
DEMO_ADMIN_PASSWORD=changeme-demo
